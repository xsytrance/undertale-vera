# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
.venv/
.pytest_cache/

# ── RAG vector index (rebuildable from knowledge/collections/*.json) ─────────
knowledge/chroma_db/
chroma.sqlite3

# ── Runtime data (read-only spine never commits uploaded saves or the DB) ────
undertale_vera.db
*.sqlite3
data/uploads/
saves/

# ── Generated art — NEVER batch-commit generated portraits ───────────────────
# The ComfyUI pixel-portrait pipeline writes here; sample relics are proof only.
static/assets/portraits/*.png
static/assets/portraits/*.jpg
static/assets/portraits/*.webp
# Route-reactive scene backdrops (same rule — pipeline + resolver committed, art not).
static/assets/scenes/*.png
static/assets/scenes/*.jpg
static/assets/scenes/*.webp
# Source art format — never commit raw art anywhere in the tree.
*.webp
# Overnight / batch art output (mirrors the FFT spine; ~GBs per run).
generation/
dogfood-output/

# ── Generated audio (the music LAYER is committed; the soundtrack is not) ────
*.mp3
static/audio/

# ── Inspector / QA artifacts (screenshots, summaries) ────────────────────────
dogfood-output/inspector/
preview/

# ── Logs, caches, secrets ────────────────────────────────────────────────────
logs/
*.log
.cache/
.env

# ── LoRA weights + training data (regenerable; never commit) ─────────────────
*.safetensors
models/loras/
dataset/
train_lora*.py

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
guided_watch.json
ember_power.json
